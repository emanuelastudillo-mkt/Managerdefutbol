{
  "version": "V3.42",
  "sistema": "hinchas",
  "descripcion": "Cantidad base de hinchas por equipo calculada desde prestigio y capacidad de estadio. La base representa hinchas activos/convocables del juego, no hinchada total histórica.",
  "caracteristicas_version": {
    "agregado": [
      "Hinchadas base para los 60 equipos.",
      "Cálculo balanceado por prestigio y capacidad del estadio.",
      "Ocupación base siempre menor a la capacidad del estadio, incluso en clubes grandes.",
      "Separación por liga para que divisiones inferiores tengan menor convocatoria promedio."
    ],
    "notas_balance": [
      "Liga Profesional: base entre 70% y 94% de capacidad según prestigio relativo.",
      "Primera Nacional: base entre 50% y 75% de capacidad según prestigio relativo.",
      "Federal A: base entre 25% y 58% de capacidad según prestigio relativo.",
      "Los valores se redondean hacia abajo para no superar el porcentaje objetivo."
    ]
  },
  "formula": {
    "descripcion": "Se normaliza el prestigio dentro de cada liga y se aplica un porcentaje de ocupación base a la capacidad del estadio.",
    "variables": {
      "prestigio_normalizado": "(prestigio - prestigio_min_liga) / (prestigio_max_liga - prestigio_min_liga)",
      "ocupacion_base": "ocupacion_min_liga + prestigio_normalizado * (ocupacion_max_liga - ocupacion_min_liga)",
      "hinchas_base": "capacidad_estadio * ocupacion_base, redondeado hacia abajo"
    },
    "rangos_por_liga": {
      "Liga Profesional": {
        "minPct": 0.7,
        "maxPct": 0.94
      },
      "Primera Nacional": {
        "minPct": 0.5,
        "maxPct": 0.75
      },
      "Federal A": {
        "minPct": 0.25,
        "maxPct": 0.58
      }
    }
  },
  "totales": {
    "equipos": 60,
    "hinchas_base_total": 926100,
    "promedio_hinchas_base": 15435.0,
    "hinchas_base_min": 200,
    "hinchas_base_max": 74500
  },
